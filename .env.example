APP_ENV=development
# Optional SQLite file path. If unset, the backend uses backend/app.db.
DATABASE_URL=

SESSION_COOKIE_NAME=contextnews_session
SESSION_EXPIRE_DAYS=7

NEWS_PROVIDER=google_news_rss
NEWS_FETCH_LIMIT=10
AI_CANDIDATE_LIMIT=5

AI_WORKER_TOKEN=change-me-worker-token
AI_WORKER_ID=local-worker
AI_WORKER_POLL_INTERVAL_SECONDS=5
CODEX_CLI_COMMAND=codex
CODEX_CLI_TIMEOUT_SECONDS=180

FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
